{
  "version": 2,
  "buildCommand": "cd backend-Automation-system && npm install && npm run build",
  "outputDirectory": "backend-Automation-system/dist",
  "installCommand": "cd backend && npm install && cd ../backend-Automation-system && npm install",
  "framework": null,
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "rewrites": [
    { "source": "/api/generate-schema", "destination": "/api/generate-schema" },
    { "source": "/api/build", "destination": "/api/build" },
    { "source": "/api/download/:projectName", "destination": "/api/download" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "env": {
    "GEMINI_API_KEY": "@gemini-api-key"
  }
}
